# 環境配置範本
# 複製此檔案並重新命名為 .env.local, .env.dev, 或 .env.prod
# 然後填入對應環境的實際配置

# 環境名稱
ENV=local

# Supabase 設定
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# JWT 設定
JWT_SECRET=e8fe31a5c8d5dca5b62113bc2910e9f59b554e473452a0033beb886b88f06a3a8afc957627fae9aae79016281298e068ae43d224714e4b300e36160271df0432afa6091d088779ed07261eb025d077dbd5d93d1e47435d9abf86833e9753950969cd001f8a4159bd64930bda95f86fade32d2bbab14606199870d55e2679d040
JWT_EXPIRATION_SECONDS=900
JWT_REFRESH_EXPIRATION_SECONDS=604800

# 除錯模式
DEBUG=true

# Redis 設定（可選，用於驗證碼、快取、限流等）
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
